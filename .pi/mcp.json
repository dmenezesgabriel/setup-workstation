{
    "mcpServers": {
        "duckdb": {
            "command": "uvx",
            "args": [
                "--python",
                "3.11",
                "mcp-server-motherduck",
                "--db-path",
                ":memory:",
                "--read-write"
            ]
        },
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ],
            "env": {
                "PLAYWRIGHT_MCP_HEADLESS": "1"
            }
        }
    }
}